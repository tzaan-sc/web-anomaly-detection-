# Sao chép file này thành .env. Không commit file .env thật.

APP_ENV=development
SECRET_KEY=replace-with-a-long-random-development-secret

# Mặc định nếu bỏ trống DATABASE_URL: SQLite tại instance/studydrive.db
# DATABASE_URL=sqlite:///instance/studydrive.db

# MySQL dùng PyMySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/studydrive
